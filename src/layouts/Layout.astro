---
import Font from 'astro/components/Font.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = "South Hills Medicine", description = "Compassionate and thorough medical care for Helena and the greater community" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <!-- SEO Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#2B4158" />
    
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://southhillsmedicine.com/og-image.jpg" />
    
    <link rel="sitemap" href="/sitemap-index.xml" />

    <Font cssVariable="--font-lato" preload />
    <Font cssVariable="--font-poppins" preload />

    <!-- Canonical URL -->
    <link rel="canonical" href={Astro.url.href} />
  </head>

  <body class="font-lato bg-white">
    <slot />
  </body>
</html>
