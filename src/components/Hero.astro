---
import { Image } from 'astro:assets';
import heroImg from '../assets/hero.jpg';

interface Props {
  title?: string;
  subtitle?: string;
  ctaText?: string;
  ctaHref?: string;
}

const {
  title = "Compassionate and thorough care for Helena and the greater community",
  subtitle = "",
  ctaText = "Call to Schedule",
  ctaHref = "tel:+14064422205"
} = Astro.props;
---

<section id="home" class="bg-gradient-to-b from-white to-gray-50">
  <div class="max-w-7xl mx-auto px-6 lg:px-8 py-12 lg:py-20">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <!-- Hero Content -->
      <div class="space-y-8">
        <h1 class="text-4xl lg:text-5xl font-bold text-brand-700 leading-tight">
          <span class="text-accent-blue">Compassionate</span> and
          <span class="text-accent-blue"> thorough</span> care for Helena and the greater community
        </h1>

        <p class="text-lg text-gray-700 leading-relaxed">
          South Hills Family Medicine provides personalized primary care focused on thorough evaluation, 
          accurate diagnosis, effective treatment, and long-term health management for adults 18 and older.
        </p>

        <a href={ctaHref}
          class="inline-flex items-center justify-center gap-2 px-6 py-4 rounded-lg bg-accent-blue text-white font-semibold shadow-lg transition-all duration-300 hover:bg-brand-700 hover:shadow-xl hover:-translate-y-0.5 focus:outline-2 focus:outline-offset-2 focus:outline-accent-blue">
          <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px"
            class="fill-white" role="img" aria-hidden="true">
            <path
              d="M798-120q-125 0-247-54.5T329-329Q229-429 174.5-551T120-798q0-18 12-30t30-12h162q14 0 25 9.5t13 22.5l26 140q2 16-1 27t-11 19l-97 98q20 37 47.5 71.5T387-386q31 31 65 57.5t72 48.5l94-94q9-9 23.5-13.5T670-390l138 28q14 4 23 14.5t9 23.5v162q0 18-12 30t-30 12ZM241-600l66-66-17-94h-89q5 41 14 81t26 79Zm358 358q39 17 79.5 27t81.5 13v-88l-94-19-67 67ZM241-600Zm358 358Z" />
          </svg>
          {ctaText}
        </a>
      </div>

      <!-- Hero Image with Optimization -->
      <div class="relative">
        <div class="aspect-square rounded-2xl overflow-hidden shadow-2xl">
          <Image
            src={heroImg}
              widths={[400, 800, 1200]}
              sizes="(max-width: 768px) 100vw, 779px"
              format="webp"
              loading="eager"
              fetchpriority="high"
              alt="Medical professional providing compassionate care at South Hills Family Medicine"
              class="w-full h-full object-cover"
              loading="eager"
              decoding="async"
          />
        </div>
        <!-- Decorative elements for visual interest -->
        <div class="absolute -bottom-4 -right-4 w-24 h-24 bg-accent-blue/10 rounded-full -z-10"></div>
        <div class="absolute -top-4 -left-4 w-32 h-32 bg-brand-500/5 rounded-full -z-10"></div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Ensure images have proper aspect ratio */
  :global(.aspect-square) {
    aspect-ratio: 1 / 1;
  }
</style>
