---
// Header component with improved accessibility and navigation
---

<header class="border-b border-gray-200 bg-white sticky top-0 z-50 shadow-sm">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="flex items-center justify-between py-4">
      <!-- Logo and Brand -->
      <a href="/" class="flex items-center gap-3 group" aria-label="South Hills Medicine - Home">
        <svg viewBox="0 0 122.73733 27.289244"
          class="w-28 h-auto transition-transform duration-300 group-hover:scale-105 fill-brand-800"
          version="1.1" xmlns="http://www.w3.org/2000/svg"
          role="img" aria-hidden="false">
          <title>South Hills Medicine Logo</title>
          <g transform="translate(-20.622932,-99.24222)">
            <path
              d="m 134.23616,123.13954 c -4.07458,-1.84944 -9.01851,-4.0748 -10.98651,-4.94524 l -3.57817,-1.58261 -10.18016,4.69209 c -5.59909,2.58065 -10.43347,4.69964 -10.743074,4.70886 -0.717593,0.0214 -1.222182,-0.58202 -1.11104,-1.32863 0.07155,-0.48062 1.311814,-1.14192 7.191704,-3.83457 3.90789,-1.78958 7.14648,-3.29501 7.19686,-3.3454 0.0504,-0.0504 -2.66576,-1.5163 -6.03588,-3.25759 -6.559124,-3.38901 -19.843795,-10.4022 -22.024561,-11.62712 l -1.322916,-0.74308 -9.392708,5.15659 c -5.16599,2.83612 -10.44622,5.72336 -11.733847,6.41609 l -2.341138,1.2595 3.238588,1.8024 c 11.358026,6.32118 13.49619,7.57793 13.638263,8.01619 0.164132,0.50631 -0.542383,1.5024 -1.065638,1.5024 -0.164133,0 -6.366356,-3.3877 -13.782718,-7.52821 -13.344715,-7.45028 -13.491149,-7.52367 -14.146506,-7.08964 -0.640412,0.42413 -18.928354,11.31924 -23.081376,13.75082 -1.986493,1.16308 -2.065691,1.18533 -2.711979,0.76186 -0.825801,-0.54108 -0.856919,-1.35255 -0.07042,-1.83626 5.681791,-3.49444 26.269716,-15.52107 26.56991,-15.52107 0.224849,0 2.330672,1.08595 4.679608,2.41321 l 4.270792,2.41322 2.645834,-1.39964 c 1.455208,-0.76981 7.28927,-3.95381 12.964582,-7.07557 l 10.31875,-5.67592 0.791405,0.453327 c 1.666136,0.954383 15.179181,8.092463 23.153385,12.230453 l 8.33438,4.32489 2.39446,-1.07859 2.39445,-1.07859 8.32117,3.6917 c 15.52062,6.88576 15.31759,6.78471 15.32857,7.6298 0.006,0.46878 -0.76749,1.14719 -1.27162,1.11516 -0.24426,-0.0155 -3.77787,-1.54139 -7.85245,-3.39083 z" />
          </g>
        </svg>
        <span
          class="text-xl font-poppins font-medium text-brand-800 transition-colors duration-300 group-hover:text-accent-blue">
          South Hills Medicine
        </span>
      </a>

      <!-- Navigation -->
      <nav class="hidden lg:flex items-center gap-8" aria-label="Main navigation">
        <a href="#home" class="nav-link text-brand-800 font-medium hover:text-accent-blue transition-colors">Home</a>
        <a href="#services" class="nav-link text-brand-800 font-medium hover:text-accent-blue transition-colors">Services</a>
        <a href="#providers"
          class="nav-link text-brand-800 font-medium hover:text-accent-blue transition-colors">Providers</a>

        <!-- Location Pin (Desktop) -->
        <a href="https://maps.google.com/?q=South+Hills+Medicine+Helena+MT" target="_blank"
          rel="noopener noreferrer"
          class="hidden xl:flex items-center gap-2 px-4 py-2 text-brand-800 hover:text-accent-blue transition-colors"
          title="View our location on Google Maps"
          aria-label="View on Google Maps">
          <svg xmlns="http://www.w3.org/2000/svg" height="20px" viewBox="0 -960 960 960" width="20px"
            class="fill-current" role="img" aria-hidden="true">
            <path
              d="M480-480q33 0 56.5-23.5T560-560q0-33-23.5-56.5T480-640q-33 0-56.5 23.5T400-560q0 33 23.5 56.5T480-480Zm0 294q122-112 181-203.5T720-552q0-109-69.5-178.5T480-800q-101 0-170.5 69.5T240-552q0 71 59 162.5T480-186Zm0 106Q319-217 239.5-334.5T160-552q0-150 96.5-239T480-880q127 0 223.5 89T800-552q0 100-79.5 217.5T480-80Zm0-480Z" />
          </svg>
        </a>

        <!-- Contact Button -->
        <a href="tel:+14064422205"
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-accent-blue text-white font-semibold shadow-md transition-all duration-300 hover:bg-brand-700 hover:shadow-lg hover:-translate-y-0.5"
          aria-label="Call us at 406-442-2205">
          <svg xmlns="http://www.w3.org/2000/svg" height="20px" viewBox="0 -960 960 960" width="20px"
            class="fill-white" role="img" aria-hidden="true">
            <path
              d="M798-120q-125 0-247-54.5T329-329Q229-429 174.5-551T120-798q0-18 12-30t30-12h162q14 0 25 9.5t13 22.5l26 140q2 16-1 27t-11 19l-97 98q20 37 47.5 71.5T387-386q31 31 65 57.5t72 48.5l94-94q9-9 23.5-13.5T670-390l138 28q14 4 23 14.5t9 23.5v162q0 18-12 30t-30 12ZM241-600l66-66-17-94h-89q5 41 14 81t26 79Zm358 358q39 17 79.5 27t81.5 13v-88l-94-19-67 67ZM241-600Zm358 358Z" />
          </svg>
          Call Us
        </a>
      </nav>

      <!-- Mobile Menu Button -->
      <div class="lg:hidden flex items-center gap-2">
        <!-- Location Pin (Mobile) -->
        <a href="https://maps.google.com/?q=South+Hills+Medicine+Helena+MT" target="_blank"
          rel="noopener noreferrer"
          class="p-2 text-brand-800 hover:bg-gray-100 rounded-md transition-colors"
          title="View our location on Google Maps"
          aria-label="View on Google Maps">
          <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px"
            class="fill-current" role="img" aria-hidden="true">
            <path
              d="M480-480q33 0 56.5-23.5T560-560q0-33-23.5-56.5T480-640q-33 0-56.5 23.5T400-560q0 33 23.5 56.5T480-480Zm0 294q122-112 181-203.5T720-552q0-109-69.5-178.5T480-800q-101 0-170.5 69.5T240-552q0 71 59 162.5T480-186Zm0 106Q319-217 239.5-334.5T160-552q0-150 96.5-239T480-880q127 0 223.5 89T800-552q0 100-79.5 217.5T480-80Zm0-480Z" />
          </svg>
        </a>

        <button class="p-2 text-brand-800 hover:bg-gray-100 rounded-md transition-colors" 
          id="mobileMenuBtn"
          aria-expanded="false"
          aria-controls="mobileMenu"
          aria-label="Toggle mobile menu">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24"
            stroke="currentColor" role="img" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile Menu -->
    <div id="mobileMenu" class="hidden lg:hidden pb-4 border-t border-gray-200">
      <nav class="flex flex-col gap-2 pt-4" aria-label="Mobile navigation">
        <a href="#home"
          class="px-4 py-2 text-brand-800 font-medium hover:bg-gray-50 rounded-md transition-colors">Home</a>
        <a href="#services"
          class="px-4 py-2 text-brand-800 font-medium hover:bg-gray-50 rounded-md transition-colors">Services</a>
        <a href="#providers"
          class="px-4 py-2 text-brand-800 font-medium hover:bg-gray-50 rounded-md transition-colors">Providers</a>
        <a href="tel:+14064422205"
          class="inline-flex items-center justify-center gap-2 px-6 py-3 mt-2 rounded-lg bg-accent-blue text-white font-semibold shadow-md">
          <svg xmlns="http://www.w3.org/2000/svg" height="20px" viewBox="0 -960 960 960" width="20px"
            class="fill-white" role="img" aria-hidden="true">
            <path
              d="M798-120q-125 0-247-54.5T329-329Q229-429 174.5-551T120-798q0-18 12-30t30-12h162q14 0 25 9.5t13 22.5l26 140q2 16-1 27t-11 19l-97 98q20 37 47.5 71.5T387-386q31 31 65 57.5t72 48.5l94-94q9-9 23.5-13.5T670-390l138 28q14 4 23 14.5t9 23.5v162q0 18-12 30t-30 12ZM241-600l66-66-17-94h-89q5 41 14 81t26 79Zm358 358q39 17 79.5 27t81.5 13v-88l-94-19-67 67ZM241-600Zm358 358Z" />
            </svg>
          Call Us
        </a>
      </nav>
    </div>
  </div>
</header>

<script>
  const mobileMenuBtn = document.getElementById('mobileMenuBtn');
  const mobileMenu = document.getElementById('mobileMenu');

  mobileMenuBtn?.addEventListener('click', () => {
    const isExpanded = mobileMenuBtn.getAttribute('aria-expanded') === 'true';
    mobileMenuBtn.setAttribute('aria-expanded', String(!isExpanded));
    mobileMenu?.classList.toggle('hidden');
  });

  // Close menu when clicking links
  document.querySelectorAll('#mobileMenu a').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenuBtn?.setAttribute('aria-expanded', 'false');
      mobileMenu?.classList.add('hidden');
    });
  });
</script>

<style>
  a:focus-visible {
    outline: 2px solid var(--color-accent-blue);
    outline-offset: 2px;
    border-radius: 0.25rem;
  }

  .nav-link {
    text-decoration: none;
    position: relative;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    width: 0;
    height: 2px;
    bottom: -2px;
    left: 0;
    background-color: var(--color-accent-blue);
    transition: width 0.3s ease;
  }

  .nav-link:hover::after {
    width: 100%;
  }
</style>
